# Doxygen configuration for usagi.

PROJECT_NAME           = "usagi"
PROJECT_BRIEF          = "Header-only C++ UI and geometry utilities"
OUTPUT_DIRECTORY       = build/docs/doxygen

INPUT                  = include/usagi
FILE_PATTERNS          = *.hpp
RECURSIVE              = YES
EXCLUDE_SYMBOLS        = *::detail::* \
                         usagi::ui::detail::* \
                         usagi::tuple::detail::* \
                         usagi::concepts::tuple::detail::* \
                         usagi::concepts::ui::detail::* \
                         usagi::type_traits::detail::* \
                         usagi::geometry::detail::*

EXTRACT_ALL            = NO
EXTRACT_PRIVATE        = NO
EXTRACT_STATIC         = NO
HIDE_UNDOC_MEMBERS     = NO
HIDE_UNDOC_CLASSES     = NO

JAVADOC_AUTOBRIEF      = YES
QT_AUTOBRIEF           = NO
MULTILINE_CPP_IS_BRIEF = NO

WARNINGS               = YES
WARN_IF_UNDOCUMENTED   = YES
WARN_IF_DOC_ERROR      = YES
WARN_NO_PARAMDOC       = YES
WARN_AS_ERROR          = NO

GENERATE_HTML          = YES
GENERATE_LATEX         = NO
GENERATE_XML           = NO

FULL_PATH_NAMES        = YES
STRIP_FROM_PATH        = .

ENABLE_PREPROCESSING   = YES
MACRO_EXPANSION        = NO
SKIP_FUNCTION_MACROS   = YES

HAVE_DOT               = NO
